generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id          String   @id @default(cuid())
  displayName String
  createdAt   DateTime @default(now())
}

model Board {
  id           String   @id @default(cuid())
  name         String
  passwordHash String?
  createdAt    DateTime @default(now())
  strokes      Stroke[]
}

model Stroke {
  id        String   @id @default(cuid())
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id])
  x0        Float
  y0        Float
  x1        Float
  y1        Float
  color     String
  width     Float
  createdAt DateTime @default(now())
}

model StickyNote {
  id        String   @id @default(cuid())
  boardId   String
  x         Float
  y         Float
  content   String   @default("")
  color     String   @default("#fef08a")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
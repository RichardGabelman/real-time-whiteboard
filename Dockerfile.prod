FROM node:22-alpine

WORKDIR /app

COPY server/package*.json ./server/
RUN cd server && npm install

COPY server ./server
COPY shared ./shared

WORKDIR /app/server

RUN npx prisma generate
RUN npm run build
RUN cp -r src/generated dist/server/src/generated

CMD ["sh", "-c", "npx prisma migrate deploy && node dist/server/src/index.js"]